@app.post("/create-payment")
@limiter.limit("5/minute")
async def create_payment(request: Request, payload: CreatePaymentRequest):
    product = payload.product
    method = payload.method

    prices = {"plus_1m": 1490, "go_12m": 1990, "plus_12m": 6990}
    
    if not PLATEGA_MERCHANT_ID or not PLATEGA_SECRET:
        logging.error("Platega credentials not configured")
        return JSONResponse({"error": "Платёжная система не настроена"}, status_code=500)

    method_map = {
        "sbp": 2,
        "card": 11,
        "crypto": 13,
    }
    
    payment_method_int = method_map.get(method, 11)

    amount = prices[product]
    order_id = str(uuid.uuid4())

    async with database:
        await database.execute(
            "INSERT INTO orders(order_id, product, amount, status) VALUES(?,?,?,'created')",
            (order_id, product, amount)
        )
        # await db.commit()  # Not needed in databases library

    url = "https://app.platega.io/transaction/process"

    data = {
        "paymentMethod": payment_method_int,
        "paymentDetails": {"amount": amount, "currency": "RUB"},
        "description": f"Подписка {product}",
        "return": f"{DOMAIN}/payment-success?order_id={order_id}",
        "failedUrl": f"{DOMAIN}/?payment=failed",
        "payload": order_id,
    }

    headers = {
        "X-MerchantId": PLATEGA_MERCHANT_ID,
        "X-Secret": PLATEGA_SECRET,
        "Content-Type": "application/json",
        "accept": "application/json",
    }

    try:
        async with httpx.AsyncClient(timeout=15) as client:
            resp = await client.post(url, json=data, headers=headers)

        if resp.status_code >= 400:
            logging.error(f"Platega error [{resp.status_code}]: {resp.text}")
            return JSONResponse({"error": "Ошибка создания платежа"}, status_code=500)

        res_json = resp.json()
    except httpx.TimeoutException:
        logging.error("Platega timeout")
        return JSONResponse({"error": "Таймаут платёжной системы"}, status_code=504)
    except Exception as e:
        logging.error(f"Payment exception: {e}")
        return JSONResponse({"error": "Ошибка соединения"}, status_code=500)

    pay_url = res_json.get("redirect")
    transaction_id = res_json.get("transactionId")

    if not pay_url:
        logging.error(f"Platega no redirect: {res_json}")
        return JSONResponse({"error": "Не получен URL оплаты"}, status_code=500)

    if transaction_id:
        async with database:
            await database.execute(
                "UPDATE orders SET transaction_id=? WHERE order_id=?",
                (transaction_id, order_id)
            )
            # await db.commit()  # Not needed in databases library

    return {"payment_url": pay_url, "order_id": order_id}

