async def get_link(token: str):
    async with database:
        cur = await database.execute(
            "SELECT token, product, status, attempts, cdk_code, last_error "
            "FROM activation_links WHERE token=?", (token,)
        )
        row = await cur.fetchone()
        if not row:
            return None
        return {
            "token": row[0], "product": row[1], "status": row[2],
            "attempts": int(row[3] or 0), "cdk_code": row[4], "last_error": row[5],
        }

async def inc_attempt(token: str, err: str):
    async with database:
        await database.execute(
            "UPDATE activation_links SET attempts=attempts+1, last_error=? WHERE token=?",
            (str(err)[:500], token)
        )
        # await db.commit()  # Not needed in databases library

async def set_link_status(token: str, status: str):
    async with database:
        await database.execute("UPDATE activation_links SET status=$1 WHERE token=$2", (status, token))
        # await db.commit()  # Not needed in databases library

async def attach_cdk(token: str, code: str):
    async with database:
        await database.execute("UPDATE activation_links SET cdk_code=$1 WHERE token=$2", (code, token))
        # await db.commit()  # Not needed in databases library

async def create_link(product: str) -> str:
    token = secrets.token_urlsafe(16)
    async with database:
        await database.execute(
            "INSERT INTO activation_links(token,product,status,attempts) VALUES(?,?,'active',0)",
            (token, product)
        )
        # await db.commit()  # Not needed in databases library
    return token

async def reserve_one_cdk(product: str):
    async with database:
        await database.execute("BEGIN IMMEDIATE")
        cur = await database.execute(
            "SELECT code FROM promo_codes WHERE product=? AND status='free' LIMIT 1",
            (product,)
        )
        row = await cur.fetchone()
        if not row:
            await database.execute("COMMIT")
            return None
        code = row[0]
        await database.execute(
            "UPDATE promo_codes SET status='reserved', reserved_at=datetime('now') WHERE code=?",
            (code,)
        )
        # await db.commit()  # Not needed in databases library
        return code

async def mark_cdk_used(code: str):
    async with database:
        await database.execute(
            "UPDATE promo_codes SET status='used', used_at=datetime('now'), last_error=NULL WHERE code=?",
            (code,)
        )
        # await db.commit()  # Not needed in databases library

async def mark_cdk_bad(code: str, err: str):
    async with database:
        await database.execute(
            "UPDATE promo_codes SET status='bad', last_error=? WHERE code=?",
            (str(err)[:500], code)
        )
        # await db.commit()  # Not needed in databases library

