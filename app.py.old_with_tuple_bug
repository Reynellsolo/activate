# ================== PLATEGA: FALLBACK ==================
@app.get("/api/fallback-check/{order_id}")
@limiter.limit("6/minute")
async def fallback_check(request: Request, order_id: str):
    if not UUID_RE.match(order_id):
        logging.warning(f"Invalid order_id format from {request.client.host}: {order_id}")
        return JSONResponse({"error": "bad order_id"}, status_code=400)

    now = int(time.time())
    last = _FALLBACK_LAST_CHECK.get(order_id, 0)
    if now - last < _FALLBACK_MIN_INTERVAL:
        return {"status": "cooldown"}
    _FALLBACK_LAST_CHECK[order_id] = now

    async with database:
        cur = await database.execute(
            "SELECT status, activation_token, transaction_id, product FROM orders WHERE order_id=?",
            (order_id,)
        )
        row = await cur.fetchone()
        if not row:
            return JSONResponse({"error": "not found"}, status_code=404)

        status, activation_token, transaction_id, product = row

        if status == "paid" and activation_token:
            return {"status": "paid", "link": f"/l/{activation_token}"}

        if not transaction_id:
            return {"status": status}

    url = f"https://app.platega.io/transaction/{transaction_id}"
    headers = {
        "X-MerchantId": PLATEGA_MERCHANT_ID,
        "X-Secret": PLATEGA_SECRET,
        "accept": "application/json",
    }

    try:
        async with httpx.AsyncClient(timeout=10) as client:
            resp = await client.get(url, headers=headers)
        if resp.status_code >= 400:
            return {"status": "pending"}
        data = resp.json()
    except Exception:
        return {"status": "pending"}

    if str(data.get("status", "")).upper() != "CONFIRMED":
        return {"status": "pending"}

    token = await create_link(product)

    async with database:
        await database.execute(
            "UPDATE orders SET status='paid', paid_at=datetime('now'), activation_token=? WHERE order_id=?",
            (token, order_id)
        )
        # await db.commit()  # Not needed in databases library

    return {"status": "paid", "link": f"/l/{token}"}

# ================== PLATEGA: WEBHOOK ==================
@app.post("/webhook/platega_bbb5ee3f3d5bbc4ed3b6aa02")
async def platega_webhook(request: Request):
    # Allow Platega webhook URL check
    ua = (request.headers.get("User-Agent") or "")
    if ua.startswith("Platega-CallbackUrlCheck"):
        return {"ok": True}

    if request.headers.get("X-MerchantId") != PLATEGA_MERCHANT_ID:
        logging.warning(f"Webhook auth fail (merchant) from {request.client.host}")
        return JSONResponse({"error": "unauthorized"}, status_code=401)
    if request.headers.get("X-Secret") != PLATEGA_SECRET:
        logging.warning(f"Webhook auth fail (secret) from {request.client.host}")
        return JSONResponse({"error": "unauthorized"}, status_code=401)

    try:
        payload = await request.json()
    except Exception:
        form = await request.form()
        payload = dict(form)

    transaction_id = payload.get("id") or payload.get("transactionId")
    status = str(payload.get("status", "")).upper()

    if status != "CONFIRMED":
        return "OK"

    if not transaction_id:
        logging.warning(f"Platega webhook missing transaction id: {payload}")
        return "OK"

    # ✅ Idempotency check
    try:
        async with database:
            await database.execute(
                "INSERT INTO platega_webhooks(transaction_id) VALUES (?)",
                (str(transaction_id),)
            )
            # await db.commit()  # Not needed in databases library
    except sqlite3.IntegrityError:
        return "OK"
    except Exception as e:
        logging.error(f"Platega webhook DB error: {repr(e)}")
        return JSONResponse({"error": "server_error"}, status_code=500)

    async with database:
        cur = await database.execute(
            "SELECT order_id, status, product FROM orders WHERE transaction_id=?",
            (str(transaction_id),)
        )
        row = await cur.fetchone()
        if not row:
            logging.warning(f"Platega webhook unknown transaction: {transaction_id}")
            return "OK"

        order_id, cur_status, product = row
        if cur_status == "paid":
            return "OK"

        token = await create_link(product)
        await database.execute(
            "UPDATE orders SET status=\"paid\", paid_at=datetime(\"now\"), activation_token=? WHERE order_id=?",
            (token, order_id)
        )
        # await db.commit()  # Not needed in databases library

    return "OK"

# ================== АКТИВАЦИЯ ==================
@app.post("/activate")
@limiter.limit("10/minute")
async def activate_submit(request: Request):
    try:
        payload = await request.json()
    except:
        return JSONResponse({"error": "Некорректный JSON"}, status_code=400)
    
    token = (payload.get("token") or "").strip()
    auth_json = (payload.get("auth_json") or "").strip()

    if not token or not auth_json:
        return JSONResponse({"error": "Пожалуйста, вставьте данные и попробуйте снова."}, status_code=400)

    link = await get_link(token)
    if not link or link["status"] != "active":
        return JSONResponse({"error": "Данная ссылка недействительна или уже была использована."}, status_code=403)

    if link["attempts"] >= MAX_ATTEMPTS:
        await set_link_status(token, "blocked")
        logging.warning(f"Token {token} blocked (max attempts) from {request.client.host}")
        return JSONResponse({"error": f"Превышен лимит попыток. Поддержка: {SUPPORT_LINK}"}, status_code=403)

    try:
        parsed = json.loads(auth_json)
        if not isinstance(parsed, dict):
            raise ValueError
    except:
        await inc_attempt(token, "invalid data")
        link2 = await get_link(token)
        if link2 and link2["attempts"] >= MAX_ATTEMPTS:
            await set_link_status(token, "blocked")
            return JSONResponse({"error": f"Превышен лимит попыток. Поддержка: {SUPPORT_LINK}"}, status_code=403)
        rem = MAX_ATTEMPTS - link2["attempts"]
        return JSONResponse({"error": f"Данные указаны некорректно. Осталось попыток: {rem}"}, status_code=400)

    code = link["cdk_code"]
    if not code:
        code = await reserve_one_cdk(link["product"])
        if not code:
            return JSONResponse({"error": f"Оформление временно недоступно. Поддержка: {SUPPORT_LINK}"}, status_code=503)
        await attach_cdk(token, code)

    try:
        authsession = parsed
        loop = asyncio.get_event_loop()
        result = await loop.run_in_executor(None, lambda: run_flow(code, authsession))
    except Exception as e:
        logging.error(f"Activation error: {e}")
        return JSONResponse({"error": "Временная техническая ошибка. Попробуйте через минуту."}, status_code=500)

    if result.get("success"):
        await mark_cdk_used(code)
        await set_link_status(token, "used")
        return {"status": "ok", "redirect": "/success"}

    # ✅ ДЕТАЛЬНАЯ ОБРАБОТКА ОШИБОК ОТ NITRO
    raw_err = result.get("error", "")
    raw_lower = raw_err.lower()

    # Сетевые ошибки (временные, НЕ увеличиваем попытки)
    if "network" in raw_lower or "timeout" in raw_lower:
        return JSONResponse({"error": "Временная ошибка соединения. Повторите через минуту."}, status_code=408)

    # Ошибки которые означают "Данные указаны некорректно"
    incorrect_data_errors = [
        "user is invalid",
        "token is invalid",
        "access token expired",
        "authorization failed",
        "invalid authorization data"
    ]
    
    is_incorrect_data = any(err in raw_lower for err in incorrect_data_errors)
    
    if is_incorrect_data:
        await inc_attempt(token, raw_err)
        link2 = await get_link(token)
        
        if link2 and link2["attempts"] >= MAX_ATTEMPTS:
            await set_link_status(token, "blocked")
            return JSONResponse({"error": f"Превышен лимит попыток. Поддержка: {SUPPORT_LINK}"}, status_code=403)
        
        rem = MAX_ATTEMPTS - link2["attempts"]
        return JSONResponse({"error": f"Данные указаны некорректно. Осталось попыток: {rem}"}, status_code=400)

    # CDK уже использован
    if "cdk already used" in raw_lower:
        await mark_cdk_bad(code, raw_err)
        await set_link_status(token, "blocked")
        logging.error(f"CDK already used: {code}")
        return JSONResponse({"error": f"Техническая ошибка. Поддержка: {SUPPORT_LINK}"}, status_code=500)

    # Проблема со статусом задачи
    if "task still pending" in raw_lower:
        await inc_attempt(token, raw_err)
        link2 = await get_link(token)
        
        if link2 and link2["attempts"] >= MAX_ATTEMPTS:
            await set_link_status(token, "blocked")
            return JSONResponse({"error": f"Превышен лимит попыток. Поддержка: {SUPPORT_LINK}"}, status_code=403)
        
        rem = MAX_ATTEMPTS - link2["attempts"]
        return JSONResponse({"error": f"Не удалось проверить статус активации. Повторите попытку. Осталось попыток: {rem}"}, status_code=408)

    # CDK не найден
    if "not found" in raw_lower and "cdk" in raw_lower:
        await mark_cdk_bad(code, raw_err)
        await set_link_status(token, "blocked")
        logging.error(f"Bad CDK {code}: {raw_err}")
        return JSONResponse({"error": f"Техническая ошибка. Поддержка: {SUPPORT_LINK}"}, status_code=500)

    # Любая другая ошибка
    await inc_attempt(token, raw_err)
    link2 = await get_link(token)
    
    if link2 and link2["attempts"] >= MAX_ATTEMPTS:
        await set_link_status(token, "blocked")
        return JSONResponse({"error": f"Превышен лимит попыток. Поддержка: {SUPPORT_LINK}"}, status_code=403)

    rem = MAX_ATTEMPTS - link2["attempts"]
    return JSONResponse({"error": f"Не удалось завершить оформление. Проверьте данные. Осталось попыток: {rem}"}, status_code=400)